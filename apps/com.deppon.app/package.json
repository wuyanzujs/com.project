{
  "name": "com.deppon.app",
  "version": "1.0.0",
  "private": true,
  "description": "deppon.app",
  "templateInfo": {
    "name": "react-native",
    "typescript": true,
    "css": "Sass",
    "framework": "React"
  },
  "scripts": {
    "dev": "taro build --type rn --watch --qr",
    "build": "taro build --type rn",
    "build:rn": "taro build --type rn",
    "dev:rn": "npm run build:rn -- --watch --qr",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "check:rn-boundaries": "node scripts/check-rn-boundaries.mjs",
    "check:routes": "node scripts/check-route-registry.mjs",
    "check:module-size": "node scripts/check-module-size.mjs",
    "check:native-env": "node scripts/check-native-env.mjs",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run check:rn-boundaries && pnpm run check:routes && pnpm run check:module-size && pnpm run build",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start --custom-log-reporter-path @tarojs/rn-supporter/TerminalReporter.js",
    "podInstall": "pod-install",
    "upgradePeerdeps": "install-peerdeps @tarojs/taro-rn@4.2.0 -o -P && install-peerdeps @tarojs/components-rn@4.2.0 -o -P && install-peerdeps @tarojs/router-rn@4.2.0 -o -P && pod-install"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.20.0",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/cli-platform-android": "^12.3.0",
    "@react-native-community/slider": "4.4.2",
    "@react-native-picker/picker": "2.6.1",
    "@react-native/gradle-plugin": "^0.73.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/stack": "^6.4.1",
    "@tarojs/components": "4.2.0",
    "@tarojs/components-rn": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/rn-supporter": "4.2.0",
    "@tarojs/router-rn": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/runtime-rn": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@tarojs/taro-rn": "4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.73.1",
    "react-native-device-info": "^14.1.1",
    "react-native-gesture-handler": "~2.14.1",
    "react-native-pager-view": "6.2.3",
    "react-native-root-siblings": "^5.0.1",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-webview": "13.6.4",
    "tsconfig-paths-webpack-plugin": "^4.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.5",
    "@react-native/babel-preset": "^0.73.18",
    "@react-native/metro-config": "^0.73.2",
    "@react-native/typescript-config": "^0.73.1",
    "@tarojs/cli": "4.2.0",
    "@tarojs/rn-runner": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.15.11",
    "@types/react": "^18.2.6",
    "@types/webpack-env": "^1.13.6",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-taro": "4.2.0",
    "eslint": "^8.19.0",
    "eslint-config-taro": "4.2.0",
    "eslint-plugin-import": "^2.12.0",
    "eslint-plugin-react": "^7.8.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "install-peerdeps": "^3.0.3",
    "pod-install": "^0.1.23",
    "postcss": "^8.4.18",
    "react-refresh": "^0.11.0",
    "stylelint": ">=16.4.0 <=16.10.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.0",
    "webpack": "^5.78.0"
  }
}
