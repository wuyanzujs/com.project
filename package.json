{
  "name": "com.project",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.13.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "dev:app": "pnpm --filter com.deppon.app dev",
    "build:app": "pnpm --filter com.deppon.app build",
    "android": "pnpm --filter com.deppon.app android",
    "ios": "pnpm --filter com.deppon.app ios",
    "start:app": "pnpm --filter com.deppon.app start",
    "typecheck:app": "pnpm --filter com.deppon.app typecheck",
    "lint:app": "pnpm --filter com.deppon.app exec eslint \"src/**/*.{ts,tsx}\"",
    "lint:app:styles": "pnpm --filter com.deppon.app lint:styles",
    "test:app-style-governance": "pnpm --filter com.deppon.app test:style-governance",
    "lint:app:fix": "pnpm --filter com.deppon.app exec eslint \"src/**/*.{ts,tsx}\" --fix",
    "check:app-boundaries": "pnpm --filter com.deppon.app check:rn-boundaries",
    "check:app-styles": "pnpm --filter com.deppon.app check:styles",
    "check:app-styles:strict": "pnpm --filter com.deppon.app check:styles:strict",
    "report:app-styles": "pnpm --filter com.deppon.app check:styles:report",
    "update:app-styles-baseline": "pnpm --filter com.deppon.app update:styles-baseline",
    "check:app-routes": "pnpm --filter com.deppon.app check:routes",
    "check:app-module-size": "pnpm --filter com.deppon.app check:module-size",
    "check:app-runtime-config": "pnpm --filter com.deppon.app check:runtime-config",
    "check:app-business-rules": "pnpm --filter com.deppon.app check:business-rules",
    "check:app-platform-build": "pnpm --filter com.deppon.app check:platform-build",
    "check:app-native-env": "pnpm --filter com.deppon.app check:native-env",
    "verify:app": "pnpm --filter com.deppon.app verify",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
