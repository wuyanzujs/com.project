{
  "name": "com.project",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev:app": "pnpm --filter com.deppon.app dev",
    "dev:mini": "pnpm --filter com.deppon.mini dev",
    "build:app": "pnpm --filter com.deppon.app build",
    "build:mini": "pnpm --filter com.deppon.mini build",
    "lint:app": "pnpm --filter com.deppon.app exec eslint \"src/**/*.{ts,tsx}\"",
    "lint:app:fix": "pnpm --filter com.deppon.app exec eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
